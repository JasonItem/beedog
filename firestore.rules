rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == 1;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /divination_history/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    match /products/{productId} {
      allow read: if (resource.data.isActive == true) || isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || isSignedIn();
    }
    
    match /orders/{orderId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
    
    match /games/{gameId}/leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }
    
    match /games/{gameId}/reviews/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /chess_rooms/{roomId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.host == request.auth.uid || isAdmin());
    }

    match /gomoku_rooms/{roomId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.host == request.auth.uid || isAdmin());
    }
  }
}